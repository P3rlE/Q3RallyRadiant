<?xml version="1.0"?>
<!--
  Q3Rally Build Menu
  [RadiantPath]  : Radiant installation directory (e.g. C:\Q3RallyRadiant\)
  [EnginePath]   : Q3Rally base directory         (e.g. C:\Q3Rally\)
  [MapFile]      : Full path to the .map / .reg file
-->
<project version="2.0">
<var name="q3map2">"[RadiantPath]q3map2.[ExecutableType]" -v<cond value="[MonitorAddress]"> -connect [MonitorAddress]</cond> -game quake3 -fs_basepath "[EnginePath]"<cond value="[GameName]"> -fs_game [GameName]</cond></var>

<!-- ═══════════════════════════════════════════════════════
     Vollständige Build-Pipelines  (BSP + VIS + Light)
     ═══════════════════════════════════════════════════════ -->

<build name="[Schnell]  BSP + VIS fast + Light fast">
<command>[q3map2] -meta -custinfoparms "[MapFile]"</command>
<command>[q3map2] -vis -fast "[MapFile]"</command>
<command>[q3map2] -light -fast -filter "[MapFile]"</command>
</build>

<build name="[Standard] BSP + VIS + Light">
<command>[q3map2] -meta -custinfoparms "[MapFile]"</command>
<command>[q3map2] -vis -saveprt "[MapFile]"</command>
<command>[q3map2] -light -fast -super 2 -filter "[MapFile]"</command>
</build>

<build name="[Final]    BSP + VIS + Light Qualität">
<command>[q3map2] -meta -custinfoparms "[MapFile]"</command>
<command>[q3map2] -vis -saveprt "[MapFile]"</command>
<command>[q3map2] -light -fast -super 2 -filter -bounce 8 "[MapFile]"</command>
</build>

<separator/>

<!-- ═══════════════════════════════════════════════════════
     Einzelschritte  (für gezieltes Nachbearbeiten)
     ═══════════════════════════════════════════════════════ -->

<build name="BSP only  (-meta -custinfoparms)">
<command>[q3map2] -meta -custinfoparms "[MapFile]"</command>
</build>

<build name="VIS only">
<command>[q3map2] -vis -saveprt "[MapFile]"</command>
</build>

<build name="VIS only  (-fast)">
<command>[q3map2] -vis -fast "[MapFile]"</command>
</build>

<build name="Light only (-fast -filter)">
<command>[q3map2] -light -fast -filter "[MapFile]"</command>
</build>

<build name="Light only (-fast -super 2 -filter)">
<command>[q3map2] -light -fast -super 2 -filter "[MapFile]"</command>
</build>

<build name="Light only (-fast -super 2 -filter -bounce 8)">
<command>[q3map2] -light -fast -super 2 -filter -bounce 8 "[MapFile]"</command>
</build>

</project>
